---
import PageLayout from "../layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
import { t, type Lang } from "../data/i18n";
import { site } from "../data/site";
import * as cvDe from "../data/cv_de";
import * as cvEn from "../data/cv_en";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const l = t(lang);
const cv = lang === "de" ? cvDe : cvEn;
const { work, education, certificates, skills } = cv;

function formatDate(dateStr: string): string {
    if (!dateStr) return "";
    const [year, month] = dateStr.split("-");
    return `${month}/${year}`;
}

const alternates = [
    { hreflang: "de", href: "https://tger.me/de/cv" },
    { hreflang: "en", href: "https://tger.me/en/cv" },
];
---

<PageLayout title={l.cvPageTitle} subtitle={l.cvPageSubtitle} description={l.cvPageDescription} ogImage={`/og/${lang}/cv.jpg`} lang={lang} alternates={alternates} revealContent={false}>
    <!-- Overview note -->
    <div class="reveal mb-8 p-4 rounded-xl bg-blue-50 dark:bg-blue-950/40 border border-blue-200 dark:border-blue-800 text-sm text-blue-800 dark:text-blue-200 flex items-start gap-2.5">
        <Icon name="tabler:info-circle" class="h-5 w-5 shrink-0 mt-0.5" />
        <p set:html={l.cvOverviewNote.replace("{contactLink}", `<a href="mailto:${site.email}" class="underline hover:text-blue-600 dark:hover:text-blue-400">${l.cvOverviewNoteLink}</a>`)} />
    </div>

    <!-- Berufserfahrung -->
    <section class="reveal mb-12">
        <h2 class="flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-200 dark:border-gray-800"><Icon name="tabler:briefcase" class="h-6 w-6 text-blue-600 dark:text-blue-400" /> {l.cvExperienceHeading}</h2>
        <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {
                work.map((job) => (
                    <div class="py-4 first:pt-0">
                        <div class="flex flex-col md:flex-row md:gap-8">
                            <div class="text-gray-900 dark:text-white md:w-25 md:shrink-0 mb-1 md:mb-0">
                                <span class="md:hidden">{job.endDate ? `${formatDate(job.startDate)} – ${formatDate(job.endDate)}` : `${l.cvSince} ${formatDate(job.startDate)}`}</span>
                                <div class="hidden md:block">
                                    {job.endDate ? (
                                        <>
                                            <div>{formatDate(job.startDate)}</div>
                                            <div>{formatDate(job.endDate)}</div>
                                        </>
                                    ) : (
                                        <>
                                            <div>{l.cvSince}</div>
                                            <div>{formatDate(job.startDate)}</div>
                                        </>
                                    )}
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                {job.position && job.position.length > 0 ? (
                                    <>
                                        <p class="font-semibold text-gray-900 dark:text-white">{job.position.join(", ")}</p>
                                        <p class="text-gray-900 dark:text-white">{job.url ? (
                                                <a href={`https://${job.url}`} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{job.name}</a>
                                            ) : job.name}{job.location && `, ${job.location}`}</p>
                                    </>
                                ) : job.location ? (
                                    <>
                                        <p class="font-semibold text-gray-900 dark:text-white">{job.typeOfEmployment}</p>
                                        <p class="text-gray-900 dark:text-white">{job.url ? (
                                                <a href={`https://${job.url}`} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{job.name}</a>
                                            ) : job.name}, {job.location}</p>
                                    </>
                                ) : (
                                    <p class="font-semibold text-gray-900 dark:text-white">{job.url ? (
                                            <a href={`https://${job.url}`} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{job.name}</a>
                                        ) : job.name}
                                    </p>
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Ausbildung -->
    <section class="reveal mb-12">
        <h2 class="flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-200 dark:border-gray-800"><Icon name="tabler:school" class="h-6 w-6 text-blue-600 dark:text-blue-400" /> {l.cvEducationHeading}</h2>
        <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {
                education.map((edu) => (
                    <div class="py-4 first:pt-0">
                        <div class="flex flex-col md:flex-row md:gap-8">
                            <div class="text-gray-900 dark:text-white md:w-25 md:shrink-0 mb-1 md:mb-0">
                                <span class="md:hidden">
                                    {formatDate(edu.startDate)} – {formatDate(edu.endDate)}
                                </span>
                                <div class="hidden md:block">
                                    <div>{formatDate(edu.startDate)}</div>
                                    <div>{formatDate(edu.endDate)}</div>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-900 dark:text-white">
                                    {edu.area}, {edu.studyType}
                                </p>
                                <p class="text-gray-900 dark:text-white">{edu.url ? (
                                        <a href={`https://${edu.url}`} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{edu.institution}</a>
                                    ) : edu.institution}{edu.location && `, ${edu.location}`}</p>
                                {edu.majorFieldOfStudy && (
                                    <p class="text-gray-900 dark:text-white">
                                        {l.cvMajorLabel} {edu.majorFieldOfStudy}
                                    </p>
                                )}
                                {edu.thesis?.title && (
                                    <p class="text-gray-900 dark:text-white mt-1">
                                        Thesis:{" "}
                                        {edu.thesis.fullTextUrl ? (
                                            <a href={edu.thesis.fullTextUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">
                                                {edu.thesis.title}
                                            </a>
                                        ) : (
                                            edu.thesis.title
                                        )}
                                    </p>
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Weiterbildung -->
    <section class="reveal mb-12">
        <h2 class="flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-200 dark:border-gray-800"><Icon name="tabler:certificate" class="h-6 w-6 text-blue-600 dark:text-blue-400" /> {l.cvFurtherEducationHeading}</h2>
        <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {
                certificates.map((cert) => (
                    <div class="py-4 first:pt-0">
                        <div class="flex flex-col md:flex-row md:gap-8">
                            <div class="text-gray-900 dark:text-white md:w-25 md:shrink-0 mb-1 md:mb-0">
                                {formatDate(cert.startDate) === formatDate(cert.endDate) ? (
                                    <span>{formatDate(cert.startDate)}</span>
                                ) : (
                                    <>
                                        <span class="md:hidden">
                                            {formatDate(cert.startDate)} – {formatDate(cert.endDate)}
                                        </span>
                                        <div class="hidden md:block">
                                            <div>{formatDate(cert.startDate)}</div>
                                            <div>{formatDate(cert.endDate)}</div>
                                        </div>
                                    </>
                                )}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-900 dark:text-white">
                                    {cert.name}
                                    {cert.degree && `, ${cert.degree}`}
                                </p>
                                <p class="text-gray-900 dark:text-white">{cert.issuerUrl ? (
                                        <a href={`https://${cert.issuerUrl}`} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{cert.issuer}</a>
                                    ) : cert.issuer}{cert.location && `, ${cert.location}`}</p>
                                {cert.url && (
                                    <a href={cert.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-1 text-xs bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 px-3 py-1 rounded-full hover:bg-blue-100 dark:hover:bg-blue-900 transition-colors">
                                        <Icon name="tabler:certificate" class="h-3.5 w-3.5" />
                                        {l.cvViewCertificate}
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Kenntnisse -->
    <section class="reveal mb-12">
        <h2 class="flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-200 dark:border-gray-800"><Icon name="tabler:brain" class="h-6 w-6 text-blue-600 dark:text-blue-400" /> {l.cvSkillsHeading}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {
                skills.map((skill) => (
                    <div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wide mb-2">{skill.name}</h3>
                        <div class="flex flex-wrap gap-2">
                            {skill.keywords.map((item) => (
                                <span class="bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white text-sm px-3 py-1 rounded-full">{item}</span>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</PageLayout>
