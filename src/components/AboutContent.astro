---
import PageLayout from "../layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { site } from "../data/site";
import { t, focusAreaStyles, type Lang } from "../data/i18n";
import portrait from "../assets/apply/2025-09-02-portrait.jpg";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const l = t(lang);

const alternates = [
    { hreflang: "de", href: "https://tger.me/de/about" },
    { hreflang: "en", href: "https://tger.me/en/about" },
];

const mottoText = lang === "de" ? site.sloganDe : site.slogan;
---

<PageLayout title={l.aboutPageTitle} subtitle={l.aboutPageSubtitle} description={l.aboutPageDescription} ogImage={`/og/${lang}/about.jpg`} lang={lang} alternates={alternates}>
    <!-- Intro card -->
    <div class="flex flex-col sm:flex-row items-center gap-6 p-6 sm:p-8 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 mb-12">
        <Image src={portrait} alt="Tristan Germer" class="w-32 h-32 sm:w-40 sm:h-40 object-cover object-top rounded-full ring-4 ring-blue-100 dark:ring-blue-900 shrink-0" widths={[128, 160, 320]} sizes="(min-width: 640px) 160px, 128px" />
        <div class="text-center sm:text-left flex-1">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Tristan Germer</h2>
            <p class="text-gray-600 dark:text-gray-400 mt-1 whitespace-pre-line">{l.aboutDegreeLabel}</p>
            <p class="text-sm text-gray-500 dark:text-gray-500">{l.aboutLocationLabel}</p>
            <div class="flex flex-wrap items-center justify-center sm:justify-start gap-3 mt-4">
                <a href={`mailto:${site.email}`} class="inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:underline">
                    <Icon name="tabler:mail" class="h-4 w-4 shrink-0" />
                    {site.email}
                </a>
                <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="inline-flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    <Icon name="tabler:phone" class="h-4 w-4 shrink-0" />
                    {site.phone}
                </a>
                <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    <Icon name="tabler:brand-linkedin-filled" class="h-4 w-4 shrink-0" />
                    LinkedIn
                </a>
            </div>
        </div>
    </div>

    <div class="space-y-12">
        <!-- Who am I? -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutWhoAmITitle}</h2>
            <div class="space-y-4 text-gray-700 dark:text-gray-300 leading-relaxed">
                {l.aboutWhoAmITexts.map((text) => <p>{text}</p>)}
            </div>
        </div>

        <!-- Focus areas -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutFocusAreasTitle}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {
                    focusAreaStyles.map((style, i) => {
                        const item = l.aboutFocusAreas[i];
                        return (
                            <div class={"p-5 rounded-xl border " + style.cardClass}>
                                <div class={"w-10 h-10 rounded-lg flex items-center justify-center mb-3 " + style.iconBoxClass}>
                                    <Icon name={style.icon} class={"h-5 w-5 " + style.iconClass} />
                                </div>
                                <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{item.title}</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400">{item.desc}</p>
                            </div>
                        );
                    })
                }
            </div>
        </div>

        <!-- What drives me -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutDrivesTitle}</h2>
            <div class="space-y-4 text-gray-700 dark:text-gray-300 leading-relaxed">
                <p>{l.aboutDrivesText}</p>
                <div class="flex">
                    <div class="w-1.5 gradient-brand shrink-0 rounded-full" />
                    <blockquote class="pl-4 italic text-gray-700 dark:text-gray-300 text-lg">{l.aboutDrivesQuote}</blockquote>
                </div>
            </div>
        </div>

        <!-- Work style -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutWorkStyleTitle}</h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{l.aboutWorkStyleText}</p>
        </div>

        <!-- Tools & Certifications -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutToolsTitle}</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">{l.aboutCertificationsLabel}</h3>
                    <div class="flex flex-wrap gap-2">
                        {["PSPO I", "PSM I", "Nanodegree iOS Development", "Projekte leiten", "Projekte managen"].map((cert) => <span class="inline-block bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 text-xs font-medium px-3 py-1 rounded-full">{cert}</span>)}
                    </div>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">{l.aboutToolsLabel}</h3>
                    <div class="flex flex-wrap gap-2">
                        {["Microsoft 365", "Power BI", "SQL", "Visio", "DMS (d.velop d3, komXwork)", "evasys", "Confluence", "Jira", "Adobe Creative Suite", "Affinity Suite", "Final Cut Pro"].map((tool) => <span class="inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-medium px-3 py-1 rounded-full">{tool}</span>)}
                    </div>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">{l.aboutAiToolsLabel}</h3>
                    <div class="flex flex-wrap gap-2">
                        {["React", "TypeScript", "Tailwind CSS", "Vite", "Astro", "Swift", "SwiftUI", "SwiftData", "D3.js", "Claude Code", "GitHub Copilot"].map((tool) => <span class="inline-block bg-purple-50 dark:bg-purple-950 text-purple-700 dark:text-purple-300 text-xs font-medium px-3 py-1 rounded-full">{tool}</span>)}
                    </div>
                </div>
            </div>
        </div>

        <!-- Motto -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{l.aboutMottoTitle}</h2>
            <div class="flex">
                <div class="w-1.5 gradient-brand shrink-0 rounded-full" />
                <blockquote class="pl-4 italic text-gray-700 dark:text-gray-300 text-lg">
                    {mottoText}
                </blockquote>
            </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 pt-2">
            <a href="/portfolio" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 transition-colors">
                <Icon name="tabler:briefcase" class="h-4 w-4" />
                {l.aboutCtaProjects}
            </a>
            <a href={`/${lang}/cv`} class="inline-flex items-center gap-2 px-5 py-2.5 border border-gray-300 dark:border-gray-700 rounded-xl font-medium hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                <Icon name="tabler:file-text" class="h-4 w-4" />
                {l.aboutCtaCv}
            </a>
            <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 border border-gray-300 dark:border-gray-700 rounded-xl font-medium hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                <Icon name="tabler:brand-linkedin-filled" class="h-4 w-4" />
                LinkedIn
            </a>
        </div>
    </div>
</PageLayout>
