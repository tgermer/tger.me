---
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  const sorted = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((project, i) => ({
    params: { slug: project.slug },
    props: {
      project,
      olderProject: sorted[i + 1] ? { slug: sorted[i + 1].slug, title: sorted[i + 1].data.title } : null,
      newerProject: sorted[i - 1] ? { slug: sorted[i - 1].slug, title: sorted[i - 1].data.title } : null,
    },
  }));
}

const { project, olderProject, newerProject } = Astro.props;
const { Content } = await project.render();
const { title, description, type, technologies, date, updatedDate, image, imageBackgroundColor, imageFit, icon, iconBackgroundColor, linkGithub, linkWebsite, screenshotsAvailable, screenshotsPath, screenshotsFiles, aiBuilt } = project.data;
const ogImage = `/og/portfolio/${project.slug}.jpg`;
---

<PortfolioLayout
  title={title}
  description={description}
  type={type}
  technologies={technologies}
  date={date}
  updatedDate={updatedDate}
  image={image}
  imageBackgroundColor={imageBackgroundColor}
  imageFit={imageFit}
  icon={icon}
  iconBackgroundColor={iconBackgroundColor}
  linkGithub={linkGithub}
  linkWebsite={linkWebsite}
  ogImage={ogImage}
  screenshotsAvailable={screenshotsAvailable}
  screenshotsPath={screenshotsPath}
  screenshotsFiles={screenshotsFiles}
  aiBuilt={aiBuilt}
  olderProject={olderProject}
  newerProject={newerProject}
>
  <Content />
</PortfolioLayout>
