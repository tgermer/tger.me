    </style>

    <script>
        // --- Toast helper ---
        function showToast(msg: string, duration = 2000) {
            const toast = document.getElementById("toast")!;
            const msgEl = document.getElementById("toast-msg")!;
            msgEl.textContent = msg;
            toast.classList.remove("opacity-0", "translate-y-2", "pointer-events-none");
            toast.classList.add("opacity-100", "translate-y-0");
            setTimeout(() => {
                toast.classList.add("opacity-0", "translate-y-2", "pointer-events-none");
                toast.classList.remove("opacity-100", "translate-y-0");
            }, duration);
        }

        // Password gate – verified server-side via Netlify Function.
        // In dev mode, skip the gate entirely.
        const isDev = import.meta.env.DEV;
        if (isDev || sessionStorage.getItem("apply-auth") === "1") {
            document.getElementById("gate")!.classList.add("hidden");
            document.getElementById("content")!.classList.remove("hidden");
        }

        // --- Extras dropdown ---
        const extrasBtn = document.getElementById("extras-btn")!;
        const extrasMenu = document.getElementById("extras-menu")!;
        extrasBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            closeAllRowMenus();
            extrasMenu.classList.toggle("hidden");
        });
        document.addEventListener("click", () => {
            extrasMenu.classList.add("hidden");
            closeAllRowMenus();
        });

        // --- Row action menus ---
        function closeAllRowMenus() {
            document.querySelectorAll(".row-menu").forEach((m) => m.classList.add("hidden"));
        }

        document.querySelectorAll(".row-menu-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                extrasMenu.classList.add("hidden");
                const menu = btn.nextElementSibling as HTMLElement;
                const wasHidden = menu.classList.contains("hidden");
                closeAllRowMenus();
                if (wasHidden) menu.classList.remove("hidden");
            });
        });

        // --- Expand/Collapse All ---
        let allExpanded = false;
        document.getElementById("expand-all-btn")?.addEventListener("click", () => {
            allExpanded = !allExpanded;
            const label = document.getElementById("expand-all-label")!;
            label.textContent = allExpanded ? "Zuklappen" : "Aufklappen";

            // Desktop rows
            document.querySelectorAll("tr[data-detail]").forEach((el) => {
                el.classList.toggle("hidden", !allExpanded);
            });
            // Mobile cards
            document.querySelectorAll("[data-expandable-card] [data-detail]").forEach((el) => {
                el.classList.toggle("hidden", !allExpanded);
            });
            // Chevron icons
            document.querySelectorAll(".expand-icon").forEach((el) => {
                el.classList.toggle("rotate-180", allExpanded);
            });
        });

        // --- Expand/Collapse ---
        document.querySelectorAll("tr[data-expandable]").forEach((row) => {
            row.addEventListener("click", (e) => {
                if ((e.target as HTMLElement).closest("a, button, .row-menu")) return;
                const detail = row.nextElementSibling;
                if (detail?.hasAttribute("data-detail")) {
                    detail.classList.toggle("hidden");
                    row.querySelector(".expand-icon")?.classList.toggle("rotate-180");
                }
            });
        });

        document.querySelectorAll("[data-expandable-card]").forEach((card) => {
            card.addEventListener("click", (e) => {
                if ((e.target as HTMLElement).closest("a, button, .row-menu")) return;
                const detail = card.querySelector("[data-detail]");
                if (detail) {
                    detail.classList.toggle("hidden");
                    card.querySelector(".expand-icon")?.classList.toggle("rotate-180");
                }
            });
        });

        // --- Sort & Search & Filter ---
        const sortLabels: Record<string, string> = { date: "Datum", update: "Update", status: "Status", company: "Firma" };
        const defaultDirs: Record<string, string> = { date: "desc", update: "desc", status: "desc", company: "asc" };
        let currentSort = { key: "date", dir: "desc" };
        let currentStatusFilter = "all";

        const terminalStatuses = new Set(["zusage", "absage", "zurückgezogen"]);

        function getVal(el: Element, key: string): string | number {
            switch (key) {
                case "date":
                    return el.getAttribute("data-date") || "";
                case "update":
                    return el.getAttribute("data-update") || "";
                case "status":
                    return parseInt(el.getAttribute("data-status-order") || "99");
                case "company":
                    return el.getAttribute("data-company") || "";
                default:
                    return "";
            }
        }

        function matchesStatusFilter(el: Element): boolean {
            if (currentStatusFilter === "all") return true;
            const key = el.getAttribute("data-status-key") || "";
            if (currentStatusFilter === "active") return !terminalStatuses.has(key);
            return key === currentStatusFilter;
        }

        function performSort() {
            const { key, dir } = currentSort;

            // Desktop table
            const tbody = document.getElementById("table-body");
            if (tbody) {
                const rows = [...tbody.querySelectorAll("tr[data-expandable]")];
                const pairs = rows.map((row) => ({
                    el: row,
                    detail: row.nextElementSibling?.hasAttribute("data-detail") ? row.nextElementSibling : null,
                }));
                pairs.sort((a, b) => {
                    const va = getVal(a.el, key);
                    const vb = getVal(b.el, key);
                    let cmp = va < vb ? -1 : va > vb ? 1 : 0;
                    if (dir === "desc") cmp = -cmp;
                    return cmp;
                });
                pairs.forEach(({ el, detail }) => {
                    tbody.appendChild(el);
                    if (detail) tbody.appendChild(detail);
                });
            }

            // Mobile cards
            const container = document.getElementById("card-container");
            if (container) {
                const cards = [...container.querySelectorAll("[data-expandable-card]")];
                cards.sort((a, b) => {
                    const va = getVal(a, key);
                    const vb = getVal(b, key);
                    let cmp = va < vb ? -1 : va > vb ? 1 : 0;
                    if (dir === "desc") cmp = -cmp;
                    return cmp;
                });
                cards.forEach((card) => container.appendChild(card));
            }

            // Update button states
            document.querySelectorAll(".sort-btn").forEach((btn) => {
                const k = btn.getAttribute("data-sort")!;
                const isActive = k === key;
                if (isActive) {
                    btn.className = "sort-btn active border border-gray-800 bg-gray-800 text-white px-2.5 py-1 rounded-full transition-colors cursor-pointer";
                    btn.textContent = `${sortLabels[k]} ${dir === "desc" ? "↓" : "↑"}`;
                } else {
                    btn.className = "sort-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer";
                    btn.textContent = sortLabels[k];
                }
            });
        }

        document.querySelectorAll(".sort-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                const key = btn.getAttribute("data-sort")!;
                if (currentSort.key === key) {
                    currentSort.dir = currentSort.dir === "desc" ? "asc" : "desc";
                } else {
                    currentSort = { key, dir: defaultDirs[key] || "desc" };
                }
                performSort();
            });
        });

        function applyFilters() {
            const q = (document.getElementById("search-input") as HTMLInputElement)?.value.toLowerCase().trim() || "";
            let visibleCount = 0;
            let totalCount = 0;

            // Desktop
            document.querySelectorAll("tr[data-expandable]").forEach((row) => {
                totalCount++;
                const text = row.getAttribute("data-search") || "";
                const matchesSearch = !q || text.includes(q);
                const matchesFilter = matchesStatusFilter(row);
                const show = matchesSearch && matchesFilter;
                row.classList.toggle("search-hidden", !show);
                if (show) visibleCount++;
                const detail = row.nextElementSibling;
                if (detail?.hasAttribute("data-detail")) {
                    if (!show) detail.classList.add("search-hidden");
                    else detail.classList.remove("search-hidden");
                }
            });

            // Mobile
            document.querySelectorAll("[data-expandable-card]").forEach((card) => {
                const text = card.getAttribute("data-search") || "";
                const matchesSearch = !q || text.includes(q);
                const matchesFilter = matchesStatusFilter(card);
                const show = matchesSearch && matchesFilter;
                card.classList.toggle("search-hidden", !show);
            });

            // Update count & empty state
            const countEl = document.getElementById("result-count");
            const emptyEl = document.getElementById("empty-state");
            const tableWrapper = document.getElementById("table-wrapper");
            const cardContainer = document.getElementById("card-container");

            if (countEl) {
                const isFiltered = q || currentStatusFilter !== "all";
                countEl.textContent = isFiltered ? `${visibleCount} von ${totalCount} Bewerbung(en)` : `${totalCount} Bewerbung(en) gespeichert.`;
            }

            if (emptyEl && tableWrapper && cardContainer) {
                if (visibleCount === 0) {
                    emptyEl.classList.remove("hidden");
                    tableWrapper.classList.add("!hidden");
                    cardContainer.classList.add("!hidden");
                } else {
                    emptyEl.classList.add("hidden");
                    tableWrapper.classList.remove("!hidden");
                    cardContainer.classList.remove("!hidden");
                }
            }
        }

        document.getElementById("search-input")?.addEventListener("input", () => applyFilters());

        // --- Status filter ---
        document.querySelectorAll(".status-filter-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                currentStatusFilter = btn.getAttribute("data-status-filter") || "all";

                // Update button states
                document.querySelectorAll(".status-filter-btn").forEach((b) => {
                    const isActive = b.getAttribute("data-status-filter") === currentStatusFilter;
                    if (isActive) {
                        b.className = "status-filter-btn border border-gray-800 bg-gray-800 text-white px-2.5 py-1 rounded-full transition-colors cursor-pointer";
                    } else {
                        b.className = "status-filter-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer";
                    }
                });

                applyFilters();
            });
        });

        // --- Keyboard shortcut: / to focus search ---
        document.addEventListener("keydown", (e) => {
            if (e.key === "/" && !(e.target as HTMLElement).matches("input, textarea, select")) {
                e.preventDefault();
                document.getElementById("search-input")?.focus();
            }
        });

        // --- Lockout ---
        document.getElementById("lockout-btn")?.addEventListener("click", () => {
            sessionStorage.removeItem("apply-auth");
            document.getElementById("content")!.classList.add("hidden");
            document.getElementById("gate")!.classList.remove("hidden");
        });

        // --- Print: expand all status histories ---
        window.addEventListener("beforeprint", () => {
            document.querySelectorAll("tr[data-detail]").forEach((el) => el.classList.remove("hidden"));
            document.querySelectorAll(".expand-icon").forEach((el) => el.classList.add("rotate-180"));
        });
        window.addEventListener("afterprint", () => {
            document.querySelectorAll("tr[data-detail]").forEach((el) => el.classList.add("hidden"));
            document.querySelectorAll(".expand-icon").forEach((el) => el.classList.remove("rotate-180"));
        });

        // --- JSON Resume copy to clipboard ---
        document.querySelectorAll<HTMLButtonElement>("[data-json-resume]").forEach((btn) => {
            btn.addEventListener("click", async (e) => {
                e.stopPropagation();
                const json = btn.getAttribute("data-json-resume");
                if (!json) return;
                try {
                    await navigator.clipboard.writeText(json);
                    showToast("JSON Resume in die Zwischenablage kopiert");
                } catch {
                    // Fallback: open in new window
                    const w = window.open("", "_blank");
                    if (w) {
                        w.document.write(`<pre>${json.replace(/</g, "&lt;")}</pre>`);
                        w.document.close();
                    }
                }
            });
        });

        // --- Password gate ---
        document.getElementById("pw-form")!.addEventListener("submit", async (e) => {
            e.preventDefault();
            const input = document.getElementById("pw-input") as HTMLInputElement;
            try {
                const res = await fetch("/.netlify/functions/check-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ password: input.value }),
                });
                const data = await res.json();
                if (data.ok) {
                    sessionStorage.setItem("apply-auth", "1");
                    document.getElementById("gate")!.classList.add("hidden");
                    document.getElementById("content")!.classList.remove("hidden");
                } else {
                    document.getElementById("pw-error")!.classList.remove("hidden");
                    input.value = "";
                    input.focus();
                }
            } catch {
                document.getElementById("pw-error")!.classList.remove("hidden");
                input.value = "";
                input.focus();
            }
        });
    </script>
</ResumeLayout>
