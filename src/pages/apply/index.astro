---
import ResumeLayout from "../../layouts/ResumeLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { site } from "../../data/site";
import { toJsonResume, type CvExports } from "../../data/json-resume";
import { existsSync } from "node:fs";
import { resolve } from "node:path";

const resumes = await getCollection("apply");

// Check which applications have a job posting PDF
const jobPdfExists = new Set<string>();
for (const r of resumes) {
    if (existsSync(resolve("public/apply", `${r.slug}-job.pdf`))) {
        jobPdfExists.add(r.slug);
    }
}

// Pre-compute JSON Resume data for each application (at build time)
const cvModules = import.meta.glob<Record<string, any>>("../../data/cv_*.ts", { eager: true });
function getJsonResume(slug: string): string | null {
    const key = `../../data/cv_${slug}.ts`;
    const mod = cvModules[key];
    if (!mod?.basics) return null;
    return JSON.stringify(toJsonResume(mod as CvExports), null, 2);
}

// Sort by date descending (newest first)
const sorted = resumes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const statusLabels: Record<string, string> = {
    gespeichert: "Gespeichert",
    beworben: "Beworben",
    eingangsbestätigung: "Eingangsbestätigung",
    vorstellungsgespräch: "Vorstellungsgespräch",
    zweitgespräch: "Zweitgespräch",
    assessment: "Assessment",
    angebot: "Angebot",
    zusage: "Zusage",
    absage: "Absage",
    zurückgezogen: "Zurückgezogen",
};

const statusColors: Record<string, string> = {
    gespeichert: "bg-yellow-50 text-yellow-700",
    beworben: "bg-gray-100 text-gray-700",
    eingangsbestätigung: "bg-blue-50 text-blue-700",
    vorstellungsgespräch: "bg-indigo-50 text-indigo-700",
    zweitgespräch: "bg-violet-50 text-violet-700",
    assessment: "bg-purple-50 text-purple-700",
    angebot: "bg-amber-50 text-amber-700",
    zusage: "bg-green-50 text-green-700",
    absage: "bg-red-50 text-red-700",
    zurückgezogen: "bg-stone-100 text-stone-500",
};

const statusDotColors: Record<string, string> = {
    gespeichert: "bg-yellow-400",
    beworben: "bg-gray-400",
    eingangsbestätigung: "bg-blue-400",
    vorstellungsgespräch: "bg-indigo-400",
    zweitgespräch: "bg-violet-400",
    assessment: "bg-purple-400",
    angebot: "bg-amber-400",
    zusage: "bg-green-400",
    absage: "bg-red-400",
    zurückgezogen: "bg-stone-400",
};

const statusOrder: Record<string, number> = {
    gespeichert: 0,
    beworben: 1,
    eingangsbestätigung: 2,
    vorstellungsgespräch: 3,
    zweitgespräch: 4,
    assessment: 5,
    angebot: 6,
    zusage: 7,
    absage: 8,
    zurückgezogen: 9,
};

// Collect which statuses actually exist in the data
const activeStatuses = [...new Set(sorted.flatMap((r) => r.data.statusHistory.map((e) => e.status)))];
const orderedActiveStatuses = activeStatuses.sort((a, b) => (statusOrder[a] ?? 99) - (statusOrder[b] ?? 99));

function getCurrentStatus(history: Array<{ status: string; date: Date }>) {
    if (history.length === 0) return null;
    const sorted = [...history].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
    return sorted[sorted.length - 1];
}

function formatDate(date: Date) {
    return new Date(date).toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" });
}

function getDisplayPosition(data: { initiative?: boolean; position?: string; lang: string }) {
    const isDE = data.lang === "de";
    const label = isDE ? "Initiativbewerbung" : "Speculative Application";
    if (data.initiative) {
        return data.position ? (isDE ? `${label} als ${data.position}` : `${label} for ${data.position}`) : label;
    }
    return data.position || "";
}

function buildContactMailto(email: string, position: string, lang: string, contact?: string, salutation?: string) {
    const greeting = salutation || (lang === "de" ? (contact ? `Hallo ${contact},` : "Sehr geehrte Damen und Herren,") : contact ? `Hello ${contact},` : "Dear Hiring Team,");
    return `mailto:${email}?subject=${encodeURIComponent(position)}&body=${encodeURIComponent(greeting + "\n\n")}`;
}

function stripMarkdown(text: string): string {
    return text
        .replace(/\*\*(.*?)\*\*/g, "$1")
        .replace(/\*(.*?)\*/g, "$1")
        .replace(/\[(.*?)\]\(.*?\)/g, "$1");
}

function buildMailtoUrl(displayPos: string, company: string, slug: string, lang: string, initiative: boolean, position?: string, email?: string, contact?: string, letterBody?: string, source?: string, salutation?: string) {
    const subject = `${displayPos} – ${site.author}`;
    const pdfUrl = `${site.url}/apply/${slug}.pdf`;
    const greeting = salutation || (lang === "de" ? (contact ? `Hallo ${contact},` : "Sehr geehrte Damen und Herren,") : contact ? `Hello ${contact},` : "Dear hiring team,");
    const pdfNote = lang === "de" ? `Meinen Lebenslauf finden Sie auch unter:\n${pdfUrl}` : `My resume is also available at:\n${pdfUrl}`;
    const closing = lang === "de" ? `Mit freundlichen Grüßen\n${site.author}` : `Best regards,\n${site.author}`;

    let intro: string;
    if (initiative) {
        if (lang === "de") {
            intro = position ? (source ? `über ${source} bin ich auf ${company} aufmerksam geworden und möchte mich initiativ als ${position} bewerben.` : `hiermit möchte ich mich initiativ als ${position} bei ${company} bewerben.`) : source ? `über ${source} bin ich auf ${company} aufmerksam geworden und möchte mich hiermit initiativ bewerben.` : `hiermit möchte ich mich initiativ bei ${company} bewerben.`;
        } else {
            intro = position ? (source ? `I came across ${company} on ${source} and would like to submit a speculative application for the ${position} role.` : `I would like to submit a speculative application for the ${position} role at ${company}.`) : source ? `I came across ${company} on ${source} and would like to submit a speculative application.` : `I would like to submit a speculative application to ${company}.`;
        }
    } else {
        if (lang === "de") {
            intro = source ? `über ${source} bin ich auf die Stelle als ${position} bei ${company} aufmerksam geworden und möchte mich hiermit bewerben.` : `hiermit möchte ich mich als ${position} bei ${company} bewerben.`;
        } else {
            intro = source ? `I came across the ${position} role at ${company} on ${source} and would like to apply.` : `I would like to apply for the ${position} role at ${company}.`;
        }
    }

    let body: string;
    if (letterBody && letterBody.trim().length > 0) {
        const content = stripMarkdown(letterBody.trim());
        body = `${greeting}\n\n${intro}\n\n${content}\n\n${pdfNote}\n\n${closing}`;
    } else {
        body = `${greeting}\n\n${intro}\n\n${pdfNote}\n\n${closing}`;
    }
    return `mailto:${email || ""}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}
---

<ResumeLayout title="Bewerbungen" description="Übersicht aller Bewerbungen" lang="de">
    <!-- Toast notification -->
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-4 py-2.5 bg-gray-900 text-white text-sm rounded-lg shadow-lg transition-all duration-300 opacity-0 translate-y-2 pointer-events-none">
        <span id="toast-msg"></span>
    </div>

    <!-- Password gate -->
    <div id="gate" class="min-h-screen flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 gradient-brand-animated opacity-95"></div>
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-white/5 blur-3xl"></div>
        <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-white/5 blur-3xl"></div>

        <div class="relative z-10 bg-white p-8 rounded-2xl shadow-xl max-w-sm w-full mx-4">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                    <Icon name="tabler:lock" class="h-5 w-5 text-blue-600" />
                </div>
                <h1 class="text-lg font-bold text-gray-900">Bewerbungen</h1>
            </div>
            <p class="text-sm text-gray-500 mb-4">Bitte Passwort eingeben, um die Übersicht anzuzeigen.</p>
            <form id="pw-form" class="flex gap-2">
                <label for="pw-input" class="sr-only">Passwort</label>
                <input id="pw-input" type="password" placeholder="Passwort" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="off" />
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">Login</button>
            </form>
            <p id="pw-error" class="text-sm text-red-500 mt-2 hidden">Falsches Passwort.</p>
        </div>
    </div>

    <!-- Protected content -->
    <div id="content" class="hidden min-h-screen bg-gray-50">
        <div class="mx-auto px-4 sm:px-6 py-6">
            <!-- Header -->
            <div class="flex items-center justify-between mb-5">
                <a href="/" class="inline-flex items-center gap-1 text-gray-500 hover:text-gray-900 transition-colors group">
                    <Icon name="tabler:chevron-left" class="h-5 w-5 print:hidden" />
                    <h1 class="text-xl font-bold text-gray-900 group-hover:text-gray-900">Bewerbungen</h1>
                </a>
                <div class="flex items-center gap-2">
                    <!-- Primary actions visible -->
                    <a href="/apply/cv-de.pdf" target="_blank" class="hidden sm:inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition-colors">
                        <Icon name="tabler:file-type-pdf" class="h-4 w-4" />PDF DE
                    </a>
                    <a href="/apply/cv-en.pdf" target="_blank" class="hidden sm:inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition-colors">
                        <Icon name="tabler:file-type-pdf" class="h-4 w-4" />PDF EN
                    </a>

                    <!-- Extras dropdown -->
                    <div class="relative" id="extras-dropdown">
                        <button id="extras-btn" class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer">
                            <Icon name="tabler:dots" class="h-4 w-4" />
                            <span class="hidden sm:inline">Extras</span>
                        </button>
                        <div id="extras-menu" class="hidden absolute right-0 mt-1 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50">
                            <a href="/de/cv-print" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <Icon name="tabler:file-text" class="h-4 w-4 text-gray-400" />Allg. Lebenslauf DE
                            </a>
                            <a href="/en/cv-print" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <Icon name="tabler:file-text" class="h-4 w-4 text-gray-400" />Allg. Lebenslauf EN
                            </a>
                            <a href="/apply/cv-de.pdf" target="_blank" class="sm:hidden flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <Icon name="tabler:file-type-pdf" class="h-4 w-4 text-gray-400" />PDF DE
                            </a>
                            <a href="/apply/cv-en.pdf" target="_blank" class="sm:hidden flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <Icon name="tabler:file-type-pdf" class="h-4 w-4 text-gray-400" />PDF EN
                            </a>
                            <div class="border-t border-gray-100 my-1"></div>
                            <button data-json-resume={getJsonResume("de")} class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 cursor-pointer">
                                <Icon name="tabler:braces" class="h-4 w-4 text-gray-400" />JSON Resume DE
                            </button>
                            <button data-json-resume={getJsonResume("en")} class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 cursor-pointer">
                                <Icon name="tabler:braces" class="h-4 w-4 text-gray-400" />JSON Resume EN
                            </button>
                        </div>
                    </div>

                    <!-- Lock button -->
                    <button id="lockout-btn" class="inline-flex items-center justify-center w-9 h-9 border border-red-200 text-red-500 rounded-lg hover:bg-red-50 hover:border-red-300 transition-colors cursor-pointer" title="Sitzung sperren">
                        <Icon name="tabler:lock" class="h-4 w-4" />
                    </button>
                </div>
            </div>

            <!-- Search, Sort & Filter bar -->
            <div class="flex flex-col gap-3 mb-4">
                <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center">
                    <div class="relative flex-1 w-full sm:max-w-xs">
                        <Icon name="tabler:search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none" />
                        <input id="search-input" type="text" placeholder="Suchen… (/ zum Fokussieren)" class="w-full pl-9 pr-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
                    </div>
                    <div class="flex gap-1.5 flex-wrap text-xs">
                        <button data-sort="date" data-dir="desc" class="sort-btn active border border-gray-800 bg-gray-800 text-white px-2.5 py-1 rounded-full transition-colors cursor-pointer">Datum ↓</button>
                        <button data-sort="update" class="sort-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer">Update</button>
                        <button data-sort="status" class="sort-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer">Status</button>
                        <button data-sort="company" class="sort-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer">Firma</button>
                        <span class="w-px h-4 bg-gray-300 self-center mx-0.5"></span>
                        <button id="expand-all-btn" class="inline-flex items-center gap-1 border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer">
                            <Icon name="tabler:arrows-maximize" class="h-3 w-3" /><span id="expand-all-label">Aufklappen</span>
                        </button>
                    </div>
                </div>

                <!-- Status filter pills -->
                <div class="flex gap-1.5 flex-wrap text-xs">
                    <button data-status-filter="all" class="status-filter-btn border border-gray-800 bg-gray-800 text-white px-2.5 py-1 rounded-full transition-colors cursor-pointer">Alle</button>
                    <button data-status-filter="active" class="status-filter-btn border border-gray-300 text-gray-600 hover:bg-gray-50 px-2.5 py-1 rounded-full transition-colors cursor-pointer">Offen</button>
                    {orderedActiveStatuses.map((status) => (
                        <button data-status-filter={status} class:list={["status-filter-btn border px-2.5 py-1 rounded-full transition-colors cursor-pointer", "border-gray-300 text-gray-600 hover:bg-gray-50"]}>
                            {statusLabels[status] || status}
                        </button>
                    ))}
                </div>
            </div>

            <p id="result-count" class="text-sm text-gray-500 mb-4">{sorted.length} Bewerbung(en) gespeichert.</p>

            <!-- Empty state -->
            <div id="empty-state" class="hidden py-16 text-center">
                <Icon name="tabler:search-off" class="h-12 w-12 text-gray-300 mx-auto mb-3" />
                <p class="text-gray-500 font-medium">Keine Bewerbungen gefunden</p>
                <p class="text-sm text-gray-400 mt-1">Versuch einen anderen Suchbegriff oder Filter.</p>
            </div>

            <!-- Mobile: stacked cards -->
            <div id="card-container" class="md:hidden flex flex-col gap-3">
                {
                    sorted.map((r) => {
                        const current = getCurrentStatus(r.data.statusHistory);
                        const statusKey = current?.status;
                        const dispPos = getDisplayPosition(r.data);
                        const history = [...r.data.statusHistory].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
                        const lastUpdate = history.length > 0 ? new Date(history[history.length - 1].date).toISOString() : new Date(r.data.date).toISOString();
                        const searchText = [
                            dispPos,
                            r.data.company,
                            r.data.contact,
                            r.data.location,
                            r.data.source,
                            r.data.notes,
                            r.data.salary,
                            statusKey ? statusLabels[statusKey] : "",
                            r.data.statusHistory
                                .map((e) => e.info)
                                .filter(Boolean)
                                .join(" "),
                        ]
                            .filter(Boolean)
                            .join(" ")
                            .toLowerCase();
                        return (
                            <div data-expandable-card data-date={new Date(r.data.date).toISOString()} data-update={lastUpdate} data-status-order={String(statusOrder[statusKey || ""] ?? 99)} data-status-key={statusKey || ""} data-company={r.data.company.toLowerCase()} data-search={searchText} class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 cursor-pointer hover:border-gray-300 hover:shadow-md active:bg-gray-50 transition-all">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <a href={`/apply/${r.slug}/`} class="font-medium text-gray-900 hover:text-blue-600 transition-colors">
                                            {dispPos}
                                        </a>
                                        <span class="ml-1.5 inline-block text-[10px] font-medium px-1.5 py-0.5 rounded bg-gray-100 text-gray-500 uppercase align-middle">{r.data.lang}</span>
                                        <p class="text-sm text-gray-500">{r.data.company}</p>
                                    </div>
                                    <div class="flex items-center gap-1 shrink-0">
                                        {statusKey && <span class:list={["text-xs font-medium px-2 py-1 rounded-full", statusColors[statusKey] || "bg-gray-100 text-gray-700"]}>{statusLabels[statusKey] || statusKey}</span>}
                                        {history.length > 0 && <Icon name="tabler:chevron-down" class="expand-icon h-3.5 w-3.5 text-gray-400 transition-transform duration-200" />}
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500 mb-3">
                                    <span class="inline-flex items-center gap-1">
                                        <Icon name="tabler:calendar" class="h-3.5 w-3.5" />
                                        {formatDate(r.data.date)}
                                    </span>
                                    {r.data.location && (
                                        <span class="inline-flex items-center gap-1">
                                            <Icon name="tabler:map-pin" class="h-3.5 w-3.5" />
                                            {r.data.location}
                                        </span>
                                    )}
                                    {r.data.source && (
                                        <span class="inline-flex items-center gap-1">
                                            <Icon name="tabler:world" class="h-3.5 w-3.5" />
                                            {r.data.source}
                                        </span>
                                    )}
                                    {r.data.salary && (
                                        <span class="inline-flex items-center gap-1">
                                            <Icon name="tabler:currency-euro" class="h-3.5 w-3.5" />
                                            {r.data.salary}
                                        </span>
                                    )}
                                </div>
                                {r.data.contact && (
                                    <p class="text-xs text-gray-500 mb-2 inline-flex items-center gap-1">
                                        <Icon name="tabler:user" class="h-3.5 w-3.5" />
                                        {r.data.contact}
                                        {r.data.contactEmail && (
                                            <span class="text-gray-400">
                                                {" "}
                                                ·{" "}
                                                <a href={buildContactMailto(r.data.contactEmail, dispPos, r.data.lang, r.data.contact, r.data.salutation)} class="hover:text-blue-600 transition-colors">
                                                    {r.data.contactEmail}
                                                </a>
                                            </span>
                                        )}
                                    </p>
                                )}
                                {r.data.notes && (
                                    <p class="text-xs text-gray-400 mb-2 truncate" title={r.data.notes}>
                                        {r.data.notes}
                                    </p>
                                )}
                                {history.length > 0 && (
                                    <div data-detail class="hidden border-t border-gray-100 pt-3 mb-2">
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Status-Verlauf</p>
                                        {history.map((entry, i) => (
                                            <div class="flex gap-3">
                                                <div class="flex flex-col items-center">
                                                    <div class:list={["w-2.5 h-2.5 rounded-full shrink-0 mt-1", statusDotColors[entry.status] || "bg-gray-400"]} />
                                                    {i < history.length - 1 && <div class="w-px flex-1 bg-gray-200 min-h-4" />}
                                                </div>
                                                <div class:list={["min-w-0", i < history.length - 1 ? "pb-3" : ""]}>
                                                    <div class="flex items-center gap-2">
                                                        <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full", statusColors[entry.status] || "bg-gray-100 text-gray-700"]}>{statusLabels[entry.status] || entry.status}</span>
                                                        <span class="text-xs text-gray-400">{formatDate(entry.date)}</span>
                                                    </div>
                                                    {entry.info && <p class="text-sm text-gray-600 mt-1 whitespace-pre-line">{entry.info}</p>}
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                )}
                                <div class="flex items-center pt-2 border-t border-gray-100">
                                    <div class="relative">
                                        <button class="row-menu-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer">
                                            <Icon name="tabler:dots" class="h-4 w-4" />
                                            <span>Aktionen</span>
                                        </button>
                                        <div class="row-menu hidden absolute left-0 bottom-full mb-1 w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50">
                                            <a href={`/apply/${r.slug}/`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                <Icon name="tabler:file-text" class="h-4 w-4 text-blue-600 shrink-0" />Lebenslauf öffnen
                                            </a>
                                            <a href={`/apply/${r.slug}.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                <Icon name="tabler:download" class="h-4 w-4 shrink-0" />CV PDF
                                            </a>
                                            {r.body && r.body.trim().length > 0 && (
                                                <a href={`/apply/${r.slug}-letter.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                    <Icon name="tabler:file-type-doc" class="h-4 w-4 shrink-0" />Anschreiben PDF
                                                </a>
                                            )}
                                            {(r.data.jobUrl || r.data.jobUrlArchived || jobPdfExists.has(r.slug) || r.data.portalUrl) && (
                                                <div class="border-t border-gray-100 my-1" />
                                            )}
                                            {r.data.jobUrl && (
                                                <a href={r.data.jobUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                    <Icon name="tabler:external-link" class="h-4 w-4 shrink-0" />Stellenanzeige
                                                </a>
                                            )}
                                            {r.data.jobUrlArchived && (
                                                <a href={r.data.jobUrlArchived} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                    <Icon name="tabler:archive" class="h-4 w-4 shrink-0" />Stellenanzeige (Archiv)
                                                </a>
                                            )}
                                            {jobPdfExists.has(r.slug) && (
                                                <a href={`/apply/${r.slug}-job.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                    <Icon name="tabler:briefcase" class="h-4 w-4 shrink-0" />Stellenanzeige (PDF)
                                                </a>
                                            )}
                                            {r.data.portalUrl && (
                                                <a href={r.data.portalUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                    <Icon name="tabler:door-enter" class="h-4 w-4 shrink-0" />Bewerberportal
                                                </a>
                                            )}
                                            <div class="border-t border-gray-100 my-1" />
                                            <a href={buildMailtoUrl(dispPos, r.data.company, r.slug, r.data.lang, r.data.initiative, r.data.position, r.data.contactEmail, r.data.contact, r.body, r.data.source, r.data.salutation)} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                <Icon name="tabler:mail" class="h-4 w-4 shrink-0" />{r.data.contactEmail ? `E-Mail an ${r.data.contactEmail}` : "E-Mail verfassen"}
                                            </a>
                                            <button data-json-resume={getJsonResume(r.slug)} class="flex items-center gap-2 w-full px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer text-left">
                                                <Icon name="tabler:braces" class="h-4 w-4 shrink-0" />JSON Resume kopieren
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        );
                    })
                }
            </div>

            <!-- Desktop: table -->
            <div id="table-wrapper" class="hidden md:block overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-200">
                <table class="w-full text-sm text-left [&_td]:align-top">
                    <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wider">
                        <tr>
                            <th class="px-4 py-3">Datum</th>
                            <th class="px-4 py-3">Position / Firma</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Kontakt</th>
                            <th class="px-4 py-3">Quelle</th>
                            <th class="px-4 py-3">Standort</th>
                            <th class="px-4 py-3">Gehalt</th>
                            <th class="px-4 py-3">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody id="table-body" class="divide-y divide-gray-100">
                        {
                            sorted.map((r) => {
                                const current = getCurrentStatus(r.data.statusHistory);
                                const statusKey = current?.status;
                                const dispPos = getDisplayPosition(r.data);
                                const history = [...r.data.statusHistory].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
                                const lastUpdate = history.length > 0 ? new Date(history[history.length - 1].date).toISOString() : new Date(r.data.date).toISOString();
                                const searchText = [
                                    dispPos,
                                    r.data.company,
                                    r.data.contact,
                                    r.data.location,
                                    r.data.source,
                                    r.data.notes,
                                    r.data.salary,
                                    statusKey ? statusLabels[statusKey] : "",
                                    r.data.statusHistory
                                        .map((e) => e.info)
                                        .filter(Boolean)
                                        .join(" "),
                                ]
                                    .filter(Boolean)
                                    .join(" ")
                                    .toLowerCase();
                                return (
                                    <>
                                        <tr data-expandable data-date={new Date(r.data.date).toISOString()} data-update={lastUpdate} data-status-order={String(statusOrder[statusKey || ""] ?? 99)} data-status-key={statusKey || ""} data-company={r.data.company.toLowerCase()} data-search={searchText} class="hover:bg-gray-50 transition-colors cursor-pointer">
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <p class="text-gray-900">{formatDate(r.data.date)}</p>
                                                <p class="text-xs text-gray-400 font-mono">{r.slug}</p>
                                            </td>
                                            <td class="px-4 py-3">
                                                <a href={`/apply/${r.slug}/`} class="font-medium text-gray-900 hover:text-blue-600 transition-colors">
                                                    {dispPos}
                                                </a>
                                                <span class="ml-1.5 inline-block text-[10px] font-medium px-1.5 py-0.5 rounded bg-gray-100 text-gray-500 uppercase align-middle">{r.data.lang}</span>
                                                <p class="text-gray-500">{r.data.company}</p>
                                                {r.data.notes && (
                                                    <p class="text-xs text-gray-400 mt-1 max-w-xs truncate" title={r.data.notes}>
                                                        {r.data.notes}
                                                    </p>
                                                )}
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <div class="flex items-center gap-1.5">
                                                    {statusKey ? <span class:list={["inline-block text-xs font-medium px-2 py-1 rounded-full", statusColors[statusKey] || "bg-gray-100 text-gray-700"]}>{statusLabels[statusKey] || statusKey}</span> : <span class="text-xs text-gray-300">–</span>}
                                                    {history.length > 0 && <Icon name="tabler:chevron-down" class="expand-icon h-3.5 w-3.5 text-gray-400 transition-transform duration-200" />}
                                                </div>
                                                {current?.date && <p class="text-xs text-gray-400 mt-1">{formatDate(current.date)}</p>}
                                            </td>
                                            <td class="px-4 py-3 text-gray-600">
                                                {r.data.contact || <span class="text-gray-300">–</span>}
                                                {r.data.contactEmail && (
                                                    <p class="text-xs text-gray-400 truncate max-w-40" title={r.data.contactEmail}>
                                                        <a href={buildContactMailto(r.data.contactEmail, dispPos, r.data.lang, r.data.contact, r.data.salutation)} class="hover:text-blue-600 transition-colors">
                                                            {r.data.contactEmail}
                                                        </a>
                                                    </p>
                                                )}
                                            </td>
                                            <td class="px-4 py-3 text-gray-600">{r.data.source || <span class="text-gray-300">–</span>}</td>
                                            <td class="px-4 py-3 text-gray-600">{r.data.location || <span class="text-gray-300">–</span>}</td>
                                            <td class="px-4 py-3 text-gray-600 whitespace-nowrap">{r.data.salary || <span class="text-gray-300">–</span>}</td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <div class="relative">
                                                    <button class="row-menu-btn inline-flex items-center justify-center w-8 h-8 rounded-md text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors cursor-pointer" title="Aktionen">
                                                        <Icon name="tabler:dots" class="h-4 w-4" />
                                                    </button>
                                                    <div class="row-menu hidden absolute right-0 mt-1 w-52 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50">
                                                        <a href={`/apply/${r.slug}/`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                            <Icon name="tabler:file-text" class="h-4 w-4 text-blue-600 shrink-0" />Lebenslauf öffnen
                                                        </a>
                                                        <a href={`/apply/${r.slug}.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                            <Icon name="tabler:download" class="h-4 w-4 shrink-0" />CV PDF
                                                        </a>
                                                        {r.body && r.body.trim().length > 0 && (
                                                            <a href={`/apply/${r.slug}-letter.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                                <Icon name="tabler:file-type-doc" class="h-4 w-4 shrink-0" />Anschreiben PDF
                                                            </a>
                                                        )}
                                                        {(r.data.jobUrl || r.data.jobUrlArchived || jobPdfExists.has(r.slug) || r.data.portalUrl) && (
                                                            <div class="border-t border-gray-100 my-1" />
                                                        )}
                                                        {r.data.jobUrl && (
                                                            <a href={r.data.jobUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                                <Icon name="tabler:external-link" class="h-4 w-4 shrink-0" />Stellenanzeige
                                                            </a>
                                                        )}
                                                        {r.data.jobUrlArchived && (
                                                            <a href={r.data.jobUrlArchived} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                                <Icon name="tabler:archive" class="h-4 w-4 shrink-0" />Stellenanzeige (Archiv)
                                                            </a>
                                                        )}
                                                        {jobPdfExists.has(r.slug) && (
                                                            <a href={`/apply/${r.slug}-job.pdf`} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                                <Icon name="tabler:briefcase" class="h-4 w-4 shrink-0" />Stellenanzeige (PDF)
                                                            </a>
                                                        )}
                                                        {r.data.portalUrl && (
                                                            <a href={r.data.portalUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                                <Icon name="tabler:door-enter" class="h-4 w-4 shrink-0" />Bewerberportal
                                                            </a>
                                                        )}
                                                        <div class="border-t border-gray-100 my-1" />
                                                        <a href={buildMailtoUrl(dispPos, r.data.company, r.slug, r.data.lang, r.data.initiative, r.data.position, r.data.contactEmail, r.data.contact, r.body, r.data.source, r.data.salutation)} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                                            <Icon name="tabler:mail" class="h-4 w-4 shrink-0" />{r.data.contactEmail ? `E-Mail an ${r.data.contactEmail}` : "E-Mail verfassen"}
                                                        </a>
                                                        <button data-json-resume={getJsonResume(r.slug)} class="flex items-center gap-2 w-full px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer text-left">
                                                            <Icon name="tabler:braces" class="h-4 w-4 shrink-0" />JSON Resume kopieren
                                                        </button>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        {history.length > 0 && (
                                            <tr data-detail class="hidden">
                                                <td colspan="8" class="px-4 py-0 bg-gray-50/50">
                                                    <div class="py-3 pl-2">
                                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Status-Verlauf</p>
                                                        {history.map((entry, i) => (
                                                            <div class="flex gap-3">
                                                                <div class="flex flex-col items-center">
                                                                    <div class:list={["w-2.5 h-2.5 rounded-full shrink-0 mt-1", statusDotColors[entry.status] || "bg-gray-400"]} />
                                                                    {i < history.length - 1 && <div class="w-px flex-1 bg-gray-200 min-h-4" />}
                                                                </div>
                                                                <div class:list={["min-w-0", i < history.length - 1 ? "pb-3" : ""]}>
                                                                    <div class="flex items-center gap-2">
                                                                        <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full", statusColors[entry.status] || "bg-gray-100 text-gray-700"]}>{statusLabels[entry.status] || entry.status}</span>
                                                                        <span class="text-xs text-gray-400">{formatDate(entry.date)}</span>
                                                                    </div>
                                                                    {entry.info && <p class="text-sm text-gray-600 mt-1 whitespace-pre-line">{entry.info}</p>}
                                                                </div>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </td>
                                            </tr>
                                        )}
                                    </>
                                );
                            })
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <style>
        .search-hidden {
            display: none !important;
        }

        @media print {
            @page {
                size: A4 landscape;
                margin: 10mm 12mm;
            }

            html,
            body {
                background: white !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            /* Hide UI chrome */
            #gate,
            #toast,
            #search-input,
            .sort-btn,
            .status-filter-btn,
            #lockout-btn,
            #extras-dropdown,
            #result-count,
            #empty-state,
            #card-container,
            #expand-all-btn,
            .expand-icon,
            .row-menu-btn,
            a[href$=".pdf"],
            a[href$="-letter.pdf"] {
                display: none !important;
            }

            /* Hide the entire header actions */
            .flex.items-center.justify-between.mb-5 .flex.items-center.gap-2 {
                display: none !important;
            }

            /* Hide filter/sort bar */
            .flex.flex-col.gap-3.mb-4 {
                display: none !important;
            }

            #result-count {
                display: none !important;
            }

            /* Show content */
            #content {
                display: block !important;
            }

            #content.hidden {
                display: block !important;
            }

            .min-h-screen {
                min-height: auto !important;
            }

            .bg-gray-50 {
                background: white !important;
            }

            /* Force desktop table visible */
            #table-wrapper {
                display: block !important;
            }

            /* Table styles */
            table {
                width: 100%;
                font-size: 8pt;
                border-collapse: collapse;
            }

            thead {
                background: #f3f4f6 !important;
            }

            th {
                font-size: 7pt;
                padding: 4px 6px !important;
                text-align: left;
            }

            td {
                padding: 4px 6px !important;
                vertical-align: top;
            }

            tr[data-expandable] {
                break-inside: avoid;
            }

            /* Show all detail rows (status history) */
            tr[data-detail] {
                display: table-row !important;
            }

            tr[data-detail] td {
                background: #fafafa !important;
                padding-top: 2px !important;
                padding-bottom: 6px !important;
            }

            /* Keep status badges readable */
            span[class*="bg-"] {
                border: 0.5px solid #d1d5db;
            }

            /* Remove shadows, borders, rounded corners */
            .shadow-sm,
            .shadow-md {
                box-shadow: none !important;
            }

            .rounded-lg {
                border-radius: 0 !important;
            }

            .border-gray-200 {
                border-color: #d1d5db !important;
            }

            /* Links column: hide in print */
            th:last-child,
            td:last-child {
                display: none;
            }

            /* Compact spacing */
            .px-4 {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }

            .py-6 {
                padding-top: 4mm !important;
                padding-bottom: 0 !important;
            }

            h1 {
                font-size: 14pt !important;
                margin-bottom: 4mm !important;
            }

            /* Disable hover styles */
            a {
                color: inherit !important;
                text-decoration: none !important;
